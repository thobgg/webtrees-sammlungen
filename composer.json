{
    "name": "thobgg/sammlungen",
    "description": "webtrees custom module – Sammlungen (Foto-Galerien mit EXIF und Lightbox)",
    "type": "webtrees-module",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Sammlungen\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sammlungen\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true,
        "autoloader-suffix": "ThobggSammlungen",
        "platform": {
            "php": "8.4"
        }
    }
}
